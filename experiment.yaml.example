schema_version: "1"
name: "agent-arena comparison"
arena_base_url: "http://127.0.0.1:8100"

repeats: 3
max_parallel_runs: 2
poll_interval_seconds: 2
poll_timeout_seconds: 7200
pass_threshold: 60

tasks:
  - env: order-desk
    all_tasks: true
    labels:
      family: tool-use
  - env: cpp-optimizer
    all_tasks: true
    labels:
      family: coding

variants:
  - name: default-agents
    compare_mode: multi-agent
    agents: [claude-code, codex]
    execution: parallel
    capture_policy: metadata

  # Same logical model through agent-specific provider routes:
  # - name: shared-model
  #   compare_mode: same-model
  #   agents: [claude-code, codex]
  #   models:
  #     claude-code: or-cc/openai/gpt-5
  #     codex: or-codex/openai/gpt-5
  #   execution: serial

  # One Agent across multiple models:
  # - name: codex-models
  #   compare_mode: multi-model
  #   agents: [codex]
  #   models:
  #     - openrouter/openai/gpt-5
  #     - openrouter/anthropic/claude-sonnet-4
