# agent-lane local config template.
# Copy to agentlane.yaml (already gitignored) and fill in real values.
# Environment variables override this file — see the comment on each field.

lane:
  # Where attempt traces / final_state / per-attempt sqlite DBs live.
  # env: LANE_DATA_PATH
  data_path: "./data"

  # Repo root for environment definitions.
  # env: LANE_ENVS_PATH
  envs_path: "./envs"

  # Address the agent-facing MCP tool server calls back to. The agent
  # process (claude/codex CLI subprocess) must be able to reach this URL.
  # Same-machine setups can leave this as loopback; if the agent runs in a
  # different network namespace (e.g. a container), point it at whatever
  # address reaches this host from there.
  # env: LANE_PUBLIC_BASE_URL
  public_base_url: "http://127.0.0.1:8100"

# Third-party model providers usable by the claude-code / codex adapters.
# Referenced from a run's `model` field as "<provider>/<model>", e.g.
# "openrouter/glm-5". API key resolution order: the named environment
# variable wins when set; if it's unset (or not configured), it falls back
# to the `api_key` field below. This file is gitignored, so filling in a
# real key here is safe — it's a convenience for when the process that
# starts the backend doesn't have the env var exported. If neither is
# available for a provider a run references, the claude-code/codex adapter
# fails the attempt immediately with `auth_failed` / `provider_api_key_missing`
# instead of letting the CLI report a confusing "not logged in" error.
#
# model_providers:
#   openrouter:
#     kind: openai-chat        # anthropic | openai-chat | openai-responses
#     base_url: "https://openrouter.ai/api/v1"
#     api_key_env: "OPENROUTER_API_KEY"
#     # api_key: "sk-or-v1-xxxx"  # optional fallback if the env var isn't set
#     wire_api: "chat"         # codex only; ignored for anthropic-kind providers

# Suggested model strings for the UI's model dropdown (free text still works).
# model_suggestions:
#   - "sonnet"
#   - "gpt-5"
#   - "openrouter/glm-5"

# Versioned Agent registry extensions. Every executable/package is installed by
# an administrator ahead of time; ordinary runs never install software.
#
# agents:
#   profiles:
#     my-profile:
#       schema_version: "1"
#       display_name: "My CLI Profile"
#       transport: local-cli
#       implementation: {kind: profile-runtime}
#       availability: {executable: my-agent}
#       launch: {executable: my-agent, args: []}
#       prompt: {mode: stdin}
#       model: {binding: agent-default}
#       mcp: {dialect: unsupported}
#       output: {parser: text}
#       capabilities: {single_turn: declared}
#       isolation: {execution_locus: host, network_required: public_internet}
#
#   # Exact ACP registry identity + raw-registry content hash. `command` is a
#   # preinstalled ACP stdio server; npx/uvx registry metadata is never invoked.
#   acp:
#     "acp:my-agent@1.2.3":
#       command: ["/opt/agents/my-agent", "--acp"]
#       registry_sha256: "sha256:aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa"
#       # registry_url: "https://cdn.agentclientprotocol.com/registry/v1/latest/registry.json"
#       permission_answers: {}  # toolCallId -> exact optionId; no implicit allow
#
#   remote:
#     remote-example:
#       endpoint: "https://agents.example.com/arena/"
#       data_residency: "eu-west"
#       upload_files: false
#       api_key_env: "REMOTE_AGENT_API_KEY"
#       supports_model: false
#       cancellation_semantics: best-effort-unknown
#
#   python_plugins:
#     python-example:
#       entrypoint: "example_agent:ExampleAgent"
#       display_name: "Example Python Agent"
#       package_name: "example-agent"
#       package_version: "0.1.0"
#       supports_model: false
#       supports_mcp: false

# Any other CLI-based agent, keyed by the agent name used in `POST /runs`.
# This is the legacy way to bring your own agent to agent-arena without writing a
# Python adapter — see backend/adapters/custom_cli.py for the full field
# reference.
#
# custom_agents:
#   my-agent:
#     command: ["my-agent-cli", "--prompt-file", "{prompt_file}"]
#     prompt_mode: file        # stdin | file | arg
#     output_format: text      # text | jsonl
