          "default": null,
          "title": "Uploads Source Files"
        }
      },
      "title": "AgentMetadata",
      "type": "object"
    },
    "AgentOptionSpec": {
      "additionalProperties": false,
      "properties": {
        "default": {
          "default": null,
          "title": "Default"
        },
        "sensitive": {
          "default": false,
          "title": "Sensitive",
          "type": "boolean"
        },
        "type": {
          "enum": [
            "string",
            "integer",
            "number",
            "boolean"
          ],
          "title": "Type",
          "type": "string"
        }
      },
      "required": [
        "type"
      ],
      "title": "AgentOptionSpec",
      "type": "object"
    },
    "AvailabilityProbeSpec": {
      "additionalProperties": false,
      "properties": {
        "configured_available": {
          "default": false,
          "title": "Configured Available",
          "type": "boolean"
        },
        "executable": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Executable"
        },
        "system_dependencies": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "System Dependencies",
          "type": "array"
        },
        "timeout_seconds": {
          "default": 2.0,
          "exclusiveMinimum": 0,
          "maximum": 30,
          "title": "Timeout Seconds",
          "type": "number"
        },
        "version_command": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Version Command",
          "type": "array"
        },
        "version_constraint": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Version Constraint"
        },
        "version_regex": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Version Regex"
        },
        "version_scheme": {
          "default": "pep440",
          "enum": [
            "pep440",
            "semver",
            "regex"
          ],
          "title": "Version Scheme",
          "type": "string"
        }
      },
      "title": "AvailabilityProbeSpec",
      "type": "object"
    },
    "CapabilitySpec": {
      "additionalProperties": false,
      "properties": {
        "answer_interaction": {
          "$ref": "#/$defs/CapabilityValue"
        },
        "mcp": {
          "$ref": "#/$defs/CapabilityValue"
        },
        "resume_send_message": {
          "$ref": "#/$defs/CapabilityValue"
        },
        "single_turn": {
          "$ref": "#/$defs/CapabilityValue"
        },
        "structured_events": {
          "$ref": "#/$defs/CapabilityValue"
        },
        "subagent_identity": {
          "$ref": "#/$defs/CapabilityValue"
        },
        "thinking": {
          "$ref": "#/$defs/CapabilityValue"
        },
        "token_usage": {
          "$ref": "#/$defs/CapabilityValue"
        },
        "tools": {
          "$ref": "#/$defs/CapabilityValue"
        },
        "wire": {
          "$ref": "#/$defs/CapabilityValue"
        }
      },
      "title": "CapabilitySpec",
      "type": "object"
    },
    "CapabilityValue": {
      "additionalProperties": false,
      "properties": {
        "basis": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Basis"
        },
        "state": {
          "default": "unsupported",
          "enum": [
            "verified",
            "declared",
            "unsupported"
          ],
          "title": "State",
          "type": "string"
        }
      },
      "title": "CapabilityValue",
      "type": "object"
    },
    "DriverSpec": {
      "additionalProperties": false,
      "properties": {
        "kind": {
          "default": "oneshot",
          "enum": [
            "oneshot",
            "command-resume"
          ],
          "title": "Kind",
          "type": "string"
        },
        "resume_args": {
          "default": [],
          "items": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "$ref": "#/$defs/LaunchArgument"
              }
            ]
          },
          "title": "Resume Args",
          "type": "array"
        }
      },
      "title": "DriverSpec",
      "type": "object"
    },
    "EnvironmentValue": {
      "additionalProperties": false,
      "properties": {
        "secret_ref": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Secret Ref"
        },
        "value": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Value"
        }
      },
      "title": "EnvironmentValue",
      "type": "object"
    },
    "FailurePatternSpec": {
      "additionalProperties": false,
      "properties": {
        "error_code": {
          "enum": [
            "agent_not_installed",
            "agent_version_unsupported",
            "agent_auth_missing",
            "agent_auth_failed",
            "agent_model_unsupported",
            "agent_rate_limited",
            "agent_usage_limit",
            "agent_network_error",
            "agent_timeout",
            "agent_cancelled",
            "agent_permission_required",
            "agent_session_invalid",
            "agent_remote_upload_not_allowed",
            "agent_nonzero_exit",
            "agent_output_parse_degraded",
            "agent_cleanup_failed",
            "agent_internal_error"
          ],
          "title": "Error Code",
          "type": "string"
        },
        "pattern": {
          "title": "Pattern",
          "type": "string"
        },
        "producer_code": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Producer Code"
        },
        "streams": {
          "default": [
            "stdout",
            "stderr"
          ],
          "items": {
            "enum": [
              "stdout",
              "stderr"
            ],
            "type": "string"
          },
          "title": "Streams",
          "type": "array"
        }
      },
      "required": [
        "error_code",
        "pattern"
      ],
      "title": "FailurePatternSpec",
      "type": "object"
    },
    "ImplementationSpec": {
      "additionalProperties": false,
      "properties": {
        "import_path": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Import Path"
        },
        "kind": {
          "enum": [
            "profile-runtime",
            "plugin",
            "existing-adapter"
          ],
          "title": "Kind",
          "type": "string"
        }
      },
      "required": [
        "kind"
      ],
      "title": "ImplementationSpec",
      "type": "object"
    },
    "IsolationSpec": {
      "additionalProperties": false,
      "properties": {
        "execution_locus": {
          "enum": [
            "host",
            "docker-sandbox",
            "remote-host"
          ],
          "title": "Execution Locus",
          "type": "string"
        },
        "inherit_user_config": {
          "default": false,
          "title": "Inherit User Config",
          "type": "boolean"
        },
        "network_required": {
          "enum": [
            "none",
            "local_service",
            "public_internet"
          ],
          "title": "Network Required",
          "type": "string"
        },
        "permission_mode": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Permission Mode"
        },
        "system_requires": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "System Requires",
          "type": "array"
        },
        "user_config_paths": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "User Config Paths",
          "type": "array"
        }
      },
      "required": [
        "execution_locus",
        "network_required"
      ],
      "title": "IsolationSpec",
      "type": "object"
    },
    "LaunchArgument": {
      "additionalProperties": false,
      "properties": {
        "flag": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Flag"
        },
        "omit_if_none": {
          "default": false,
          "title": "Omit If None",
          "type": "boolean"
        },
        "value": {
          "title": "Value",
          "type": "string"
        }
      },
      "required": [
        "value"
      ],
      "title": "LaunchArgument",
      "type": "object"
    },
    "LaunchSpec": {
      "additionalProperties": false,
      "properties": {
        "args": {
          "default": [],
          "items": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "$ref": "#/$defs/LaunchArgument"
              }
            ]
          },
          "title": "Args",
          "type": "array"
        },
        "cwd": {
          "default": "attempt_workspace",
          "enum": [
            "attempt_workspace",
            "project",
            "attempt_private"
          ],
          "title": "Cwd",
          "type": "string"
        },
        "env": {
          "additionalProperties": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "$ref": "#/$defs/EnvironmentValue"
              }
            ]
          },
          "title": "Env",
          "type": "object"
        },
        "executable": {
          "title": "Executable",
          "type": "string"
        },
        "shell": {
          "default": false,
          "title": "Shell",
          "type": "boolean"
        },
        "shell_reason": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Shell Reason"
        }
      },
      "required": [
        "executable"
      ],
      "title": "LaunchSpec",
      "type": "object"
    },
    "McpDialectSpec": {
      "additionalProperties": false,
      "properties": {
        "config_flag": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
