          "default": null,
          "title": "Config Flag"
        },
        "dialect": {
          "enum": [
            "json-file",
            "command-register",
            "native-config",
            "unsupported"
          ],
          "title": "Dialect",
          "type": "string"
        }
      },
      "required": [
        "dialect"
      ],
      "title": "McpDialectSpec",
      "type": "object"
    },
    "ModelBindingSpec": {
      "additionalProperties": false,
      "properties": {
        "binding": {
          "enum": [
            "flag",
            "environment",
            "config-file",
            "agent-default",
            "unsupported"
          ],
          "title": "Binding",
          "type": "string"
        },
        "default_model": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Default Model"
        },
        "env_var": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Env Var"
        },
        "flag": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Flag"
        },
        "protocols": {
          "default": [],
          "items": {
            "enum": [
              "anthropic",
              "openai-chat",
              "openai-responses",
              "agent-cloud",
              "model-proxy"
