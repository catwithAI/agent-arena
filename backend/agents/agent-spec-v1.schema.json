            "type": "string"
          },
          "title": "Protocols",
          "type": "array"
        }
      },
      "required": [
        "binding"
      ],
      "title": "ModelBindingSpec",
      "type": "object"
    },
    "OutputSpec": {
      "additionalProperties": false,
      "properties": {
        "config": {
          "additionalProperties": true,
          "title": "Config",
          "type": "object"
        },
        "parser": {
          "enum": [
            "text",
            "jsonl",
            "native-session",
            "atif",
            "plugin"
          ],
          "title": "Parser",
          "type": "string"
        },
        "parser_import_path": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Parser Import Path"
        },
        "parser_version": {
          "default": "1",
          "title": "Parser Version",
          "type": "string"
        }
      },
      "required": [
        "parser"
      ],
      "title": "OutputSpec",
      "type": "object"
    },
    "PromptSpec": {
      "additionalProperties": false,
      "properties": {
        "arg_fallback": {
          "default": "error",
          "enum": [
            "file",
            "stdin",
            "error"
          ],
          "title": "Arg Fallback",
          "type": "string"
        },
        "mode": {
          "enum": [
            "stdin",
            "file",
            "arg",
            "driver-owned"
          ],
          "title": "Mode",
          "type": "string"
        }
      },
      "required": [
        "mode"
      ],
      "title": "PromptSpec",
      "type": "object"
    },
    "SecretRefSpec": {
      "additionalProperties": false,
      "properties": {
        "env_var": {
          "title": "Env Var",
          "type": "string"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "required": {
          "default": true,
          "title": "Required",
          "type": "boolean"
        }
      },
      "required": [
        "name",
        "env_var"
      ],
      "title": "SecretRefSpec",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "auth": {
      "default": [],
      "items": {
        "$ref": "#/$defs/SecretRefSpec"
      },
      "title": "Auth",
      "type": "array"
    },
    "availability": {
      "$ref": "#/$defs/AvailabilityProbeSpec"
    },
    "capabilities": {
      "$ref": "#/$defs/CapabilitySpec"
    },
    "display_name": {
      "title": "Display Name",
      "type": "string"
    },
    "driver": {
      "$ref": "#/$defs/DriverSpec"
    },
    "failure_patterns": {
      "default": [],
      "items": {
        "$ref": "#/$defs/FailurePatternSpec"
      },
      "title": "Failure Patterns",
      "type": "array"
    },
    "id": {
      "title": "Id",
      "type": "string"
    },
    "implementation": {
      "$ref": "#/$defs/ImplementationSpec"
    },
    "isolation": {
      "$ref": "#/$defs/IsolationSpec"
    },
    "launch": {
      "anyOf": [
        {
          "$ref": "#/$defs/LaunchSpec"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "mcp": {
      "$ref": "#/$defs/McpDialectSpec"
    },
    "metadata": {
      "$ref": "#/$defs/AgentMetadata"
    },
    "model": {
      "$ref": "#/$defs/ModelBindingSpec"
    },
    "options": {
      "additionalProperties": {
        "$ref": "#/$defs/AgentOptionSpec"
      },
      "title": "Options",
      "type": "object"
    },
    "output": {
      "$ref": "#/$defs/OutputSpec"
    },
    "prompt": {
      "$ref": "#/$defs/PromptSpec"
    },
    "schema_version": {
      "const": "1",
      "title": "Schema Version",
      "type": "string"
    },
    "source": {
      "enum": [
        "builtin",
        "config",
        "config-override",
        "plugin",
        "legacy"
      ],
      "title": "Source",
      "type": "string"
    },
    "transport": {
      "enum": [
        "local-cli",
        "ssh-cli",
        "acp",
        "python-sdk",
        "remote"
      ],
      "title": "Transport",
      "type": "string"
    },
    "warnings": {
      "default": [],
      "items": {
        "type": "string"
      },
      "title": "Warnings",
      "type": "array"
    }
  },
  "required": [
    "schema_version",
    "id",
    "display_name",
    "source",
    "transport",
    "implementation",
    "prompt",
    "model",
    "mcp",
    "output",
    "isolation"
  ],
  "title": "AgentSpec",
  "type": "object"
}
